<div class="flex items-center justify-between gap-4 mb-4">
  <div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">← {{ eventName }}</a><h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1></div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:36rem">
  <form method="post" action="{{ action }}">
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">Name</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="name" required placeholder="Member discount" value="{{ values.name }}"></label>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">Code</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono" name="code" required placeholder="MEMBER20" value="{{ values.code }}"></label>
    <div class="flex gap-4 mb-3">
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Type</span>
        <select class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="kind">
          <option value="percent"{% if values.kind == 'percent' %} selected{% endif %}>Percent off</option>
          <option value="fixed"{% if values.kind == 'fixed' %} selected{% endif %}>Fixed amount off</option>
        </select>
      </label>
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Amount (% or money)</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="amount" required inputmode="decimal" placeholder="20" value="{{ values.amount }}"></label>
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Currency (fixed only)</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="currency" maxlength="3" value="{{ values.currency }}"></label>
    </div>
    <div class="flex gap-4 mb-3">
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Max uses</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="max_uses" inputmode="numeric" placeholder="unlimited" value="{{ values.max_uses }}"></label>
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Valid from</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="datetime-local" name="start" value="{{ values.start }}"></label>
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Until</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="datetime-local" name="end" value="{{ values.end }}"></label>
    </div>
    {% if values.used_count != '0' %}<p class="text-sm text-gray-500 mb-3">Redeemed so far: {{ values.used_count }}</p>{% endif %}
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit">Save promo code</button>
  </form>
  {% if deleteAction != blank %}
  <form method="post" action="{{ deleteAction }}" onsubmit="return confirm('Delete this promo code?')" class="mt-1">
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg text-sm font-semibold text-red-600 hover:bg-red-50 hover:text-red-700 px-4 cursor-pointer" type="submit">Delete</button>
  </form>
  {% endif %}
</div>
