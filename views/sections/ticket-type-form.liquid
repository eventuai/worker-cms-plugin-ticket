<div class="flex items-center justify-between gap-4 mb-4">
  <div><a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">← {{ eventName }}</a><h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1></div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" style="max-width:36rem">
  <form method="post" action="{{ action }}">
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">Name</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="name" required placeholder="Early bird" value="{{ values.name }}"></label>
    <label class="block mb-3"><span class="block text-sm text-gray-700 mb-1">Description</span><textarea class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="description" rows="3">{{ values.description }}</textarea></label>
    <div class="flex gap-4 mb-3">
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Price</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="price" required inputmode="decimal" placeholder="120.00" value="{{ values.price }}"></label>
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Currency</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="currency" maxlength="3" placeholder="hkd" value="{{ values.currency }}"></label>
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Quantity cap</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" name="quantity" inputmode="numeric" placeholder="unlimited" value="{{ values.quantity }}"></label>
    </div>
    <div class="flex gap-4 mb-3">
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">On sale from</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="datetime-local" name="start" value="{{ values.start }}"></label>
      <label class="block w-full"><span class="block text-sm text-gray-700 mb-1">Until</span><input class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" type="datetime-local" name="end" value="{{ values.end }}"></label>
    </div>
    <label class="block mb-3"><input type="checkbox" name="active" value="true"{% if values.active == 'true' %} checked{% endif %}> <span class="text-sm text-gray-700">On sale (active)</span></label>
    {% if values.sold != '0' %}<p class="text-sm text-gray-500 mb-3">Sold so far: {{ values.sold }}</p>{% endif %}
    <div class="flex items-center justify-between gap-4">
      <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 cursor-pointer" type="submit">Save ticket type</button>
    </div>
  </form>
  {% if deleteAction != blank %}
  <form method="post" action="{{ deleteAction }}" onsubmit="return confirm('Delete this ticket type?')" class="mt-1">
    <button class="inline-flex h-10 items-center justify-center gap-2 rounded-lg text-sm font-semibold text-red-600 hover:bg-red-50 hover:text-red-700 px-4 cursor-pointer" type="submit">Delete</button>
  </form>
  {% endif %}
</div>
